# Keep the directory contract but not fetched or generated datasets.
data/raw/**
data/interim/**
data/processed/**
data/external/**
!data/**/.gitkeep
reports/figures/**
reports/tables/**

# Version publication figures and compact research tables. Large row-level outputs
# (descriptive_summary.csv and efficiency_predictions.csv) remain reproducible but ignored.
!reports/figures/*.png
!reports/tables/calibration_*.csv
!reports/tables/efficiency_metrics.csv
!reports/tables/efficiency_coefficients.csv
!reports/tables/extreme_*.csv
!reports/tables/information_*.csv
!reports/tables/liquidity_*.csv
!reports/tables/market_vs_forecast_relationship.csv
!reports/tables/weather_forecast_revisions.csv
